<launch>
    <arg name="name" default="emotion_recognition"/>
    <arg name="language" default="en"/>  <!-- Options: fr or en -->
    <arg name="inference_type" default="torchscript"/>
    <arg name="window_secs" default="4"/>
    <arg name="neural_network_inference_type" default="torch_gpu"/> <!-- Options: cpu, torch_gpu or trt_gpu -->
    <arg name="camera_2d_wide_enabled" default="false"/>
    <arg name="weight_video" default="0.3"/>
    <arg name="weight_audio" default="0.3"/>
    <arg name="weight_text" default="0.4">

    
    <!-- Base robot -->
    <include file="$(find-pkg-share t_top)/launch/bringup.launch.xml">
        <arg name="language" value="$(var language)"/>
        <arg name="camera_2d_wide_enabled" value="$(var camera_2d_wide_enabled)"/>
        <arg name="slam" value="false"/>
        <arg name="open_browser" value="false"/>
    </include>

    <node pkg="control_panel" exec="control_panel_node" name="control_panel_node" output="screen">
        <param name="camera_2d_wide_enabled" value="$(var camera_2d_wide_enabled)"/>
    </node>

    <node pkg="emotion_recognition" exec="emotion_recognition_node.py" name="emotion_recognition_node" output="screen">
        <param name="inference_type" value="$(var inference_type)"/>
        <param name="window_secs" value="$(var window_secs)"/>
        <remap from="analysed_image" to="camera_3d/analysed_image"/>
        <remap from="emotion_audio_in" to="audio_input_signed_16_16000"/>
        <param name="weight_video" to="$(var weight_video)"/>
        <param name="weight_audio" to="$(var weight_audio)"/>
        <param name="weight_text" to="$(var weight_text)"/>
    </node>
</launch>

